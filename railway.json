{
  "$schema": "https://railway.com/reference/config-as-code",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm install && npm run build --workspace=packages/web",
    "watchPatterns": ["packages/web/**", "packages/llm/**"]
  },
  "deploy": {
    "startCommand": "cp -r packages/web/.next/static packages/web/.next/standalone/packages/web/.next/static && node packages/web/.next/standalone/packages/web/server.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
